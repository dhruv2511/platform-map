b:["$","div",null,{"className":"card","children":[["$","h3",null,{"children":"🔐 2. Databricks Account Setup"}],["$","p",null,{"children":["$","strong",null,{"children":"Timeline: 1 day"}]}],["$","h4",null,{"children":"Databricks Account Requirements:"}],["$","ul",null,{"children":[["$","li",null,{"children":[["$","strong",null,{"children":"Databricks Account"}],["$","p",null,{"children":["Sign up at ",["$","a",null,{"href":"https://accounts.cloud.databricks.com","target":"_blank","rel":"noopener noreferrer","children":"accounts.cloud.databricks.com"}],". Choose AWS as your cloud provider."]}]]}],["$","li",null,{"children":[["$","strong",null,{"children":"Account Tier"}],["$","p",null,{"children":["• ",["$","strong",null,{"children":"Standard:"}]," Perfect for learning, development, single team (most cost-effective)",["$","br",null,{}],"• ",["$","strong",null,{"children":"Premium:"}]," For multiple teams, advanced security, essential for production",["$","br",null,{}],"• ",["$","strong",null,{"children":"Enterprise:"}]," For large organizations with compliance needs (HIPAA, SOC2)"]}]]}],["$","li",null,{"children":[["$","strong",null,{"children":"Unity Catalog Enabled"}],["$","p",null,{"children":"Unity Catalog is Databricks' centralized governance engine. It's required in this setup. Ensure your account tier supports it (Premium/Enterprise)."}]]}],["$","li",null,{"children":[["$","strong",null,{"children":"Account ID"}],["$","p",null,{"children":"Find your Databricks Account ID in the Account Console (top-left corner). You'll need this for every deployment."}]]}]]}],["$","h4",null,{"children":"Create OAuth Application (for CI/CD):"}],["$","ol",null,{"children":[["$","li",null,{"children":"Log in to Databricks Account Console"}],["$","li",null,{"children":["Go to ",["$","strong",null,{"children":"Admin Settings → OAuth Applications"}]]}],["$","li",null,{"children":["Click ",["$","strong",null,{"children":"Create Service Principal"}]]}],["$","li",null,{"children":["Name it: ",["$","code",null,{"children":"bootstrap-cicd"}]]}],["$","li",null,{"children":["Select ",["$","strong",null,{"children":"Account Admin"}]," permissions"]}],["$","li",null,{"children":"Generate OAuth Secret and save it securely"}]]}],["$","h4",null,{"children":"Resources Created in Databricks:"}],["$","ul",null,{"children":[["$","li",null,{"children":"Account-level service principals (dev, staging, prod)"}],["$","li",null,{"children":"Workspaces (one per environment)"}],["$","li",null,{"children":"Unity Catalog metastores (shared or per-workspace)"}]]}]]}]
c:["$","div",null,{"className":"card","children":[["$","h3",null,{"children":"🔄 3. GitHub & CI/CD Setup"}],["$","p",null,{"children":["$","strong",null,{"children":"Timeline: 1 day"}]}],["$","h4",null,{"children":"Git Repository:"}],["$","ul",null,{"children":[["$","li",null,{"children":[["$","strong",null,{"children":"Repository Access"}],["$","p",null,{"children":"You need access to GitHub repositories containing the infrastructure code (fork or clone the aws_dbx repositories)"}]]}],["$","li",null,{"children":[["$","strong",null,{"children":"Branch Protection"}],["$","p",null,{"children":["Set up branch protection on ",["$","code",null,{"children":"main"}]," to prevent direct commits.",["$","br",null,{}],"• Require pull request reviews before merge",["$","br",null,{}],"• Require status checks to pass (Terraform plan)"]}]]}]]}],["$","h4",null,{"children":"GitHub Secrets (for automated deployments):"}],["$","p",null,{"children":"Add these to your GitHub repository settings:"}],["$","ul",null,{"children":[["$","li",null,{"children":[["$","code",null,{"children":"AWS_ACCOUNT_ID"}],": Your AWS account ID"]}],["$","li",null,{"children":[["$","code",null,{"children":"DATABRICKS_ACCOUNT_ID"}],": Your Databricks account ID"]}],["$","li",null,{"children":[["$","code",null,{"children":"DATABRICKS_CLIENT_ID"}],": OAuth client ID from step 2"]}],["$","li",null,{"children":[["$","code",null,{"children":"DATABRICKS_CLIENT_SECRET"}],": OAuth secret (marked as secret)"]}],["$","li",null,{"children":[["$","code",null,{"children":"AWS_REGION"}],": Your target AWS region (e.g., us-east-1)"]}]]}],["$","h4",null,{"children":"OIDC Configuration (Recommended):"}],["$","p",null,{"children":"Instead of storing AWS credentials, use OpenID Connect (OIDC) federation:"}],["$","ul",null,{"children":[["$","li",null,{"children":"GitHub Actions can assume AWS roles without storing long-term credentials"}],["$","li",null,{"children":"Setup happens during the backend bootstrap stage"}],["$","li",null,{"children":"More secure and compliant with best practices"}]]}]]}]
d:["$","div",null,{"className":"card","children":[["$","h3",null,{"children":"🌐 4. Understanding Your Network Architecture"}],["$","p",null,{"children":["$","strong",null,{"children":"Timeline: 1-2 days (planning only)"}]}],["$","p",null,{"children":"Choose your networking architecture before deployment. This determines how Databricks connects to your systems."}],["$","div",null,{"className":"subcard","children":[["$","h4",null,{"children":"Pattern 1: Standalone VPC (Default for Dev/Test)"}],["$","p",null,{"children":[["$","strong",null,{"children":"Best for:"}]," Small teams, development, proof-of-concepts"]}],["$","p",null,{"children":[["$","strong",null,{"children":"Architecture:"}]," Single VPC with Databricks workspace + managed connections to external systems"]}],["$","ul",null,{"children":[["$","li",null,{"children":"✅ Simplest to deploy and understand"}],["$","li",null,{"children":"✅ Cost-effective ($300-500/month for dev)"}],["$","li",null,{"children":"✅ Good for learning and testing"}],["$","li",null,{"children":"❌ Not ideal for production with existing infrastructure"}]]}],["$","p",null,{"children":["$","strong",null,{"children":"Typical Setup:"}]}],["$","pre",null,{"className":"prereq-code","children":"VPC (10.0.0.0/16) ├── Public Subnet (for NAT Gateway) └── Private Subnet (Databricks clusters)"}]]}],["$","div",null,{"className":"subcard","children":[["$","h4",null,{"children":"Pattern 2: With Network Firewall (Production)"}],["$","p",null,{"children":[["$","strong",null,{"children":"Best for:"}]," Production environments with compliance needs"]}],["$","p",null,{"children":[["$","strong",null,{"children":"Architecture:"}]," Standalone + AWS Network Firewall for traffic inspection"]}],["$","ul",null,{"children":[["$","li",null,{"children":"✅ Enhanced security and traffic monitoring"}],["$","li",null,{"children":"✅ Meets compliance requirements (SOC2, HIPAA placeholders)"}],["$","li",null,{"children":"✅ Detailed logging and threat detection"}],["$","li",null,{"children":"❌ Slightly higher cost (~$100/month additional)"}]]}],["$","p",null,{"children":["$","strong",null,{"children":"Typical Setup:"}]}],["$","pre",null,{"className":"prereq-code","children":"VPC (10.0.0.0/16) ├── NAT Gateway (egress) ├── Network Firewall (inspection point) └── Databricks Subnets"}]]}],["$","div",null,{"className":"subcard subcard-focus","children":[["$","h4",null,{"children":"Pattern 3: Hub-Spoke Architecture (Enterprise/Multi-Environment)"}],["$","p",null,{"children":[["$","strong",null,{"children":"Best for:"}]," Organizations with multiple workspaces, shared services, or complex networks"]}],["$","p",null,{"children":["$","strong",null,{"children":"Why Hub-Spoke?"}]}],["$","ul",null,{"children":[["$","li",null,{"children":[["$","strong",null,{"children":"Centralized Management:"}]," One hub VPC for shared services (databases, data lakes, monitoring)"]}],["$","li",null,{"children":[["$","strong",null,{"children":"Environment Isolation:"}]," Each environment (dev/staging/prod) gets its own spoke VPC"]}],["$","li",null,{"children":[["$","strong",null,{"children":"Cost Efficiency:"}]," Shared infrastructure reduces redundancy"]}],["$","li",null,{"children":[["$","strong",null,{"children":"Security:"}]," Network segmentation and controlled inter-VPC communication"]}]]}],["$","h5",null,{"children":"🔑 Key Concepts for Hub-Spoke:"}],["$","ul",null,{"children":[["$","li",null,{"children":[["$","strong",null,{"children":"Hub VPC:"}]," Shared services, data warehouses, authentication services, monitoring"]}],["$","li",null,{"children":[["$","strong",null,{"children":"Spoke VPCs:"}]," Individual Databricks workspaces (dev, staging, prod)"]}],["$","li",null,{"children":[["$","strong",null,{"children":"Transit Gateway:"}]," Connects hub to all spokes automatically"]}],["$","li",null,{"children":[["$","strong",null,{"children":"Private Link:"}]," Secure connectivity between Databricks and AWS services"]}]]}],["$","h5",null,{"children":"Architecture Diagram:"}],["$","pre",null,{"className":"prereq-code","children":"Hub VPC (10.0.0.0/16) - Shared Services\n├── Shared Databases\n├── Central Data Lake  \n├── Monitoring & Logging\n└── Network Firewall (optional central)\n       ↓\nTransit Gateway (TGW) - Central Routing\n       ↓\n   ┌───┴───────┬───────────┐\n   ↓           ↓           ↓\nDev Spoke    Staging      Prod Spoke\n(10.1.0/16)  Spoke       (10.3.0/16)\n             (10.2.0/16)\n    ↓         ↓            ↓\n  DBX Dev   DBX Stg      DBX Prod\n  Cluster   Cluster      Cluster"}],"$L1a","$L1b","$L1c","$L1d","$L1e","$L1f"]}],"$L20","$L21","$L22"]}]
e:["$","div",null,{"className":"card","children":[["$","h3",null,{"children":"🛠️ 5. Developer Tools & Environment"}],["$","p",null,{"children":["$","strong",null,{"children":"Timeline: Half day to install and configure"}]}],["$","h4",null,{"children":"Required Tools:"}],["$","ul",null,{"children":[["$","li",null,{"children":[["$","strong",null,{"children":"Terraform v1.13.3 or later"}],["$","p",null,{"children":["Infrastructure-as-Code tool used for AWS and Databricks deployment.",["$","br",null,{}],["$","a",null,{"href":"https://www.terraform.io/downloads","target":"_blank","rel":"noopener noreferrer","children":"Download Terraform"}]," |",["$","a",null,{"href":"https://learn.hashicorp.com/tutorials/terraform/install-cli","target":"_blank","rel":"noopener noreferrer","children":" Installation Guide"}]]}]]}],["$","li",null,{"children":[["$","strong",null,{"children":"AWS CLI v2+"}],["$","p",null,{"children":["Command-line tool to interact with AWS services.",["$","br",null,{}],["$","a",null,{"href":"https://docs.aws.amazon.com/cli/latest/userguide/getting-started-install.html","target":"_blank","rel":"noopener noreferrer","children":"Installation Guide"}],["$","br",null,{}],["$","code",null,{"children":"aws configure"}]," - Setup your AWS credentials"]}]]}],["$","li",null,{"children":[["$","strong",null,{"children":"Git (Version Control)"}],["$","p",null,{"children":["For managing infrastructure code and CI/CD workflows.",["$","br",null,{}],["$","a",null,{"href":"https://git-scm.com/book/en/v2/Getting-Started-Installing-Git","target":"_blank","rel":"noopener noreferrer","children":"Installation Guide"}]]}]]}],["$","li",null,{"children":[["$","strong",null,{"children":"Databricks CLI (Optional but Recommended)"}],["$","p",null,{"children":["Interact with Databricks from command line.",["$","br",null,{}],["$","code",null,{"children":"pip install databricks-cli"}]]}]]}]]}],["$","h4",null,{"children":"Verification Checklist:"}],["$","pre",null,{"className":"prereq-code","children":"# Verify installations:\nterraform --version          # Should be 1.13.3+\naws --version               # Should be 2.0+\ngit --version              # Should be 2.30+\n\n# Verify AWS credentials configured\naws sts get-caller-identity  # Should return your user/role\n\n# Verify AWS permissions\naws s3 ls                   # Can list buckets\naws ec2 describe-vpcs       # Can list VPCs"}]]}]
f:["$","div",null,{"className":"card","children":[["$","h3",null,{"children":"💾 6. Data & Storage Preparation"}],["$","p",null,{"children":["$","strong",null,{"children":"Timeline: 1-2 days"}]}],["$","h4",null,{"children":"S3 Buckets Needed:"}],["$","ul",null,{"children":[["$","li",null,{"children":[["$","strong",null,{"children":"Terraform State Bucket"}]," (created during backend setup)",["$","p",null,{"children":"Stores Terraform state files. Created automatically by bootstrap script."}]]}],["$","li",null,{"children":[["$","strong",null,{"children":"Databricks Root Storage Bucket"}],["$","p",null,{"children":["Workspace data files. Created during workspace provisioning. Example: ",["$","code",null,{"children":"my-project-dbx-root-dev"}]]}]]}],["$","li",null,{"children":[["$","strong",null,{"children":"Unity Catalog Metastore Bucket"}],["$","p",null,{"children":["Data governance storage. Example: ",["$","code",null,{"children":"my-project-dbx-metastore"}]]}]]}],["$","li",null,{"children":[["$","strong",null,{"children":"Audit Logs Bucket"}]," (Optional but recommended)",["$","p",null,{"children":["Stores Databricks audit logs for compliance. Example: ",["$","code",null,{"children":"my-project-dbx-audit-logs"}]]}]]}]]}],["$","h4",null,{"children":"Data Migration Planning:"}],["$","ul",null,{"children":[["$","li",null,{"children":[["$","strong",null,{"children":"Identify Data Sources:"}]," Where is your data currently? (On-prem database, other cloud, S3, etc.)"]}],["$","li",null,{"children":[["$","strong",null,{"children":"Volume Estimation:"}]," How much data needs to move? (Impacts network and timeline)"]}],["$","li",null,{"children":[["$","strong",null,{"children":"Migration Strategy:"}]," Batch, streaming, or hybrid approach?"]}],["$","li",null,{"children":[["$","strong",null,{"children":"Access Patterns:"}]," Who needs access? (Data lineage and governance)"]}]]}]]}]
10:["$","div",null,{"className":"card","children":[["$","h3",null,{"children":"🔒 7. Security & Compliance Checklist"}],["$","p",null,{"children":["$","strong",null,{"children":"Timeline: Day 1 (planning) + Ongoing"}]}],["$","h4",null,{"children":"Essential Security Steps:"}],["$","ul",null,{"children":[["$","li",null,{"children":[["$","strong",null,{"children":"Enable AWS CloudTrail"}],["$","p",null,{"children":"Audit all AWS API calls for compliance."}]]}],["$","li",null,{"children":[["$","strong",null,{"children":"Enable VPC Flow Logs"}],["$","p",null,{"children":"Monitor network traffic to/from Databricks workspaces."}]]}],["$","li",null,{"children":[["$","strong",null,{"children":"Encrypt Data in Transit"}],["$","p",null,{"children":"All communication uses TLS 1.2+. VPC endpoints keep traffic private."}]]}],["$","li",null,{"children":[["$","strong",null,{"children":"Encrypt Data at Rest"}],["$","p",null,{"children":"S3 buckets encrypted with AWS KMS or S3-managed keys."}]]}],["$","li",null,{"children":[["$","strong",null,{"children":"Implement Least Privilege IAM"}],["$","p",null,{"children":"Each role/user has minimum permissions needed."}]]}],["$","li",null,{"children":[["$","strong",null,{"children":"Enable MFA on AWS Root Account"}],["$","p",null,{"children":"Protect root account from unauthorized access."}]]}]]}],["$","h4",null,{"children":"Compliance Considerations:"}],["$","ul",null,{"children":[["$","li",null,{"children":[["$","strong",null,{"children":"SOC2:"}]," Audit trails, encryption, access controls (✅ Supported)"]}],["$","li",null,{"children":[["$","strong",null,{"children":"HIPAA:"}]," Requires encryption, audit logs, PHI handling (✅ Supported with right config)"]}],["$","li",null,{"children":[["$","strong",null,{"children":"PCI-DSS:"}]," Network segmentation, encryption, access logs (✅ Supported)"]}],["$","li",null,{"children":[["$","strong",null,{"children":"GDPR:"}]," Data residency, right to delete, data classification (✅ Supported with proper setup)"]}]]}],["$","p",null,{"children":[["$","strong",null,{"children":"📋 Action Items:"}]," Discuss compliance requirements with your security team during planning."]}]]}]
11:["$","div",null,{"className":"card","children":[["$","h3",null,{"children":"🤝 8. Personnel & Third-Party Technology Dependencies"}],["$","p",null,{"children":["$","strong",null,{"children":"Timeline: Confirm before deployment week (ideally Day 1-2)"}]}],["$","h4",null,{"children":"Required People / Teams:"}],["$","ul",null,{"children":[["$","li",null,{"children":[["$","strong",null,{"children":"Cloud Platform Owner:"}]," Can approve IAM roles, networking, and account guardrails"]}],["$","li",null,{"children":[["$","strong",null,{"children":"Network Team:"}]," Owns routing, Transit Gateway, firewall rules, and private DNS behavior"]}],["$","li",null,{"children":[["$","strong",null,{"children":"Security Team:"}]," Approves encryption, audit logging, and least-privilege policies"]}],["$","li",null,{"children":[["$","strong",null,{"children":"Identity Team:"}]," Owns SSO/SCIM, enterprise app approval, and group sync"]}],["$","li",null,{"children":[["$","strong",null,{"children":"DNS/Domain Team (often third party):"}]," Owns CNAME/zone updates and TTL windows"]}],["$","li",null,{"children":[["$","strong",null,{"children":"Data Owners:"}]," Approve source access and data movement windows"]}]]}],["$","h4",null,{"children":"Third-Party / External Dependencies:"}],["$","ul",null,{"children":[["$","li",null,{"children":[["$","strong",null,{"children":"DNS Change Windows:"}]," Confirm who controls DNS and what lead time is required (24-72h typical)"]}],["$","li",null,{"children":[["$","strong",null,{"children":"Corporate PKI / Certificates:"}]," If custom domains or private endpoints use enterprise cert processes"]}],["$","li",null,{"children":[["$","strong",null,{"children":"Firewall Vendor / SOC:"}]," If egress rules are managed outside cloud platform team"]}],["$","li",null,{"children":[["$","strong",null,{"children":"ITSM Approval Flow:"}]," Change tickets required for production cutovers"]}],["$","li",null,{"children":[["$","strong",null,{"children":"SaaS Integrations:"}]," Downstream tools (BI, orchestration, observability) may require vendor-side setup"]}]]}],["$","h4",null,{"children":"Example: DNS Cutover Dependency (Common Blocker)"}],["$","ul",null,{"children":[["$","li",null,{"children":[["$","strong",null,{"children":"Dependency:"}]," Third-party DNS provider must create/update CNAME for workspace vanity URL"]}],["$","li",null,{"children":[["$","strong",null,{"children":"Owner:"}]," Network or domain team (not data platform team)"]}],["$","li",null,{"children":[["$","strong",null,{"children":"Lead Time:"}]," Often 1-3 business days + CAB approval"]}],["$","li",null,{"children":[["$","strong",null,{"children":"Technical Inputs Needed:"}]," Target hostname, record type, TTL, rollback value"]}],["$","li",null,{"children":[["$","strong",null,{"children":"Risk if missed:"}]," Workspace unreachable on go-live domain even if infrastructure is healthy"]}]]}],["$","h4",null,{"children":"Dependency Readiness Checklist:"}],["$","ul",null,{"children":[["$","li",null,{"children":"☐ Named owner for each external dependency"}],["$","li",null,{"children":"☐ SLA/lead time documented for DNS, firewall, and identity changes"}],["$","li",null,{"children":"☐ Change ticket IDs tracked for production go-live"}],["$","li",null,{"children":"☐ Backout plan documented (old DNS target + rollback TTL)"}],["$","li",null,{"children":"☐ Freeze period conflicts checked (e.g., end-of-month, holiday freeze)"}],["$","li",null,{"children":"☐ Escalation contact list available for cutover day"}]]}],["$","h4",null,{"children":"RACI for External Dependencies (Kickoff Template)"}],["$","table",null,{"style":{"width":"100%","marginTop":12,"borderCollapse":"collapse"},"children":[["$","thead",null,{"children":["$","tr",null,{"style":{"backgroundColor":"#f0f0f0"},"children":[["$","th",null,{"style":{"border":"1px solid #ddd","padding":8,"textAlign":"left"},"children":"Activity"}],["$","th",null,{"style":{"border":"1px solid #ddd","padding":8,"textAlign":"left"},"ch