{
  "version": 3,
  "pages404": true,
  "caseSensitive": false,
  "basePath": "",
  "redirects": [
    {
      "source": "/:path+/",
      "destination": "/:path+",
      "internal": true,
      "statusCode": 308,
      "regex": "^(?:/((?:[^/]+?)(?:/(?:[^/]+?))*))/$"
    }
  ],
  "headers": [],
  "rewrites": {
    "beforeFiles": [],
    "afterFiles": [],
    "fallback": []
  },
  "dynamicRoutes": [],
  "staticRoutes": [
    {
      "page": "/",
      "regex": "^/(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/(?:/)?$"
    },
    {
      "page": "/_not-found",
      "regex": "^/_not\\-found(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/_not\\-found(?:/)?$"
    },
    {
      "page": "/aws-framework",
      "regex": "^/aws\\-framework(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/aws\\-framework(?:/)?$"
    },
    {
      "page": "/databricks-framework",
      "regex": "^/databricks\\-framework(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/databricks\\-framework(?:/)?$"
    },
    {
      "page": "/deployment",
      "regex": "^/deployment(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/deployment(?:/)?$"
    },
    {
      "page": "/implementation",
      "regex": "^/implementation(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/implementation(?:/)?$"
    },
    {
      "page": "/maturity",
      "regex": "^/maturity(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/maturity(?:/)?$"
    },
    {
      "page": "/modules",
      "regex": "^/modules(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/modules(?:/)?$"
    },
    {
      "page": "/overview",
      "regex": "^/overview(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/overview(?:/)?$"
    },
    {
      "page": "/prerequisites",
      "regex": "^/prerequisites(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/prerequisites(?:/)?$"
    },
    {
      "page": "/prerequisites-tracker",
      "regex": "^/prerequisites\\-tracker(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/prerequisites\\-tracker(?:/)?$"
    },
    {
      "page": "/PrerequisitesPage",
      "regex": "^/PrerequisitesPage(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/PrerequisitesPage(?:/)?$"
    }
  ],
  "dataRoutes": [],
  "rsc": {
    "header": "rsc",
    "varyHeader": "rsc, next-router-state-tree, next-router-prefetch, next-router-segment-prefetch",
    "prefetchHeader": "next-router-prefetch",
    "didPostponeHeader": "x-nextjs-postponed",
    "contentTypeHeader": "text/x-component",
    "suffix": ".rsc",
    "prefetchSuffix": ".prefetch.rsc",
    "prefetchSegmentHeader": "next-router-segment-prefetch",
    "prefetchSegmentSuffix": ".segment.rsc",
    "prefetchSegmentDirSuffix": ".segments"
  },
  "rewriteHeaders": {
    "pathHeader": "x-nextjs-rewritten-path",
    "queryHeader": "x-nextjs-rewritten-query"
  }
}